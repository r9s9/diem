{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "diem",
  "version": "0.1.0",
  "identifier": "com.diem.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "diem",
        "width": 1040,
        "height": 720,
        "minWidth": 880,
        "minHeight": 600,
        "visible": true,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/128x128.png",
      "tooltip": "diem"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Private work-activity tracker",
    "longDescription": "diem privately tracks your work on this device and helps you turn it into a client timesheet."
  }
}
